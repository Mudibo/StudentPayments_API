{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AspNetCoreRateLimit": "Debug"
    }
  },
  "ConnectionStrings": { 
    "DefaultConnection": "${ConnectionStrings__DefaultConnection}" ,
    "Redis": "${ConnectionStrings__Redis}"
    },
  "Jwt": {
    "Secret": "${Jwt__Secret}",
    "Issuer": "${Jwt__Issuer}",
    "Audience": "${Jwt__Audience}",
    "TokenLifetimeMinutes": "${Jwt__TokenLifetimeMinutes}"
  },
  "IpRateLimiting": {
        "EnableEndpointRateLimiting": true,
        "StackBlockedRequests": false,
        "RealIpHeader": "X-Forwarded-For",
        "HttpStatusCode": 429,
        "GeneralRules": [
          {
            "Endpoint": "post:/api/oauth/token",
            "Period": "1m",
            "Limit": 2
          }
        ]
  }
}